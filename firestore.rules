rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can only access their own data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Plants subcollection: users/{uid}/plants/{plantId}
      match /plants/{plantId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;

        allow create: if request.auth != null
          && request.auth.uid == uid
          && isValidPlant(request.resource.data);

        allow update: if request.auth != null
          && request.auth.uid == uid
          && isValidPlantUpdate(request.resource.data);
      }
    }
  }

  function isValidIntervalField(data, field) {
    // Accepts int (active) or empty string (cleared/disabled)
    return !(field in data)
      || data[field] is int
      || data[field] == '';
  }

  function isValidPlant(data) {
    return data.name is string
      && data.name.size() > 0
      && data.name.size() <= 100
      && data.createdAt is timestamp
      && data.updatedAt is timestamp
      && (!('notes' in data) || data.notes is string)
      && (!('imageUrl' in data) || data.imageUrl is string)
      && (!('watering' in data) || data.watering is string)
      && (!('sunlight' in data) || data.sunlight is string)
      && (!('fertilization' in data) || data.fertilization is string)
      && (!('sprinkling' in data) || data.sprinkling is string)
      && (!('wateringMode' in data) || data.wateringMode in ['disabled', 'interval'])
      && (!('fertilizationMode' in data) || data.fertilizationMode in ['disabled', 'interval', 'with_watering'])
      && (!('sprinklingMode' in data) || data.sprinklingMode in ['disabled', 'interval'])
      && isValidIntervalField(data, 'wateringIntervalDays')
      && isValidIntervalField(data, 'fertilizationIntervalDays')
      && isValidIntervalField(data, 'fertilizationEveryWaterings')
      && isValidIntervalField(data, 'sprinklingIntervalDays')
      && (!('lastWateredAt' in data) || data.lastWateredAt is timestamp)
      && (!('lastFertilizedAt' in data) || data.lastFertilizedAt is timestamp)
      && (!('lastSprinkledAt' in data) || data.lastSprinkledAt is timestamp);
  }

  function isValidPlantUpdate(data) {
    return data.updatedAt is timestamp
      && (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
      && (!('notes' in data) || data.notes is string)
      && (!('imageUrl' in data) || data.imageUrl is string)
      && (!('watering' in data) || data.watering is string)
      && (!('sunlight' in data) || data.sunlight is string)
      && (!('fertilization' in data) || data.fertilization is string)
      && (!('sprinkling' in data) || data.sprinkling is string)
      && (!('wateringMode' in data) || data.wateringMode in ['disabled', 'interval'])
      && (!('fertilizationMode' in data) || data.fertilizationMode in ['disabled', 'interval', 'with_watering'])
      && (!('sprinklingMode' in data) || data.sprinklingMode in ['disabled', 'interval'])
      && isValidIntervalField(data, 'wateringIntervalDays')
      && isValidIntervalField(data, 'fertilizationIntervalDays')
      && isValidIntervalField(data, 'fertilizationEveryWaterings')
      && isValidIntervalField(data, 'sprinklingIntervalDays')
      && (!('lastWateredAt' in data) || data.lastWateredAt is timestamp)
      && (!('lastFertilizedAt' in data) || data.lastFertilizedAt is timestamp)
      && (!('lastSprinkledAt' in data) || data.lastSprinkledAt is timestamp);
  }
}
